# Deployed settings — only the .tpl is tracked
settings.json

# Runtime and ephemeral state
history.jsonl
backups/
cache/
todos/
projects/
shell-snapshots/
statsig/
session-env/
sessions/
telemetry/
plans/

# Machine-specific config
policy-limits.json

# Plugin state (marketplace downloads, personal blocklist)
plugins/

# IDE integration state
ide/

# Backup dirs created by setup.sh
.dotfiles-backup-*/

# Third-party skills installed via `npx skills add` (Claude Code's
# ~/.claude/skills is symlinked to extensions/skills/, so installs land here).
# First-party skills authored in this repo are explicitly un-ignored below.
extensions/skills/*
!extensions/skills/.gitkeep
!extensions/skills/mermaid/
!extensions/skills/devserver/
!extensions/skills/file-docs/
!extensions/skills/tdd/
!extensions/skills/readme-badges/

# macOS
.DS_Store
